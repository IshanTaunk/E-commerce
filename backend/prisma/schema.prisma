generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Hotel {
  id          String   @id @default(cuid())
  name        String
  city        String
  state       String
  description String
  rating      Float
  reviewCount Int
  thumbnail   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
